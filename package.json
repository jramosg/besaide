{
	"name": "besaide",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.33.0",
	"license": "MIT",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"check": "astro check",
		"build": "astro check && astro build",
		"preview": "pnpm run build && astro preview",
		"test": "vitest run",
		"optimize:images": "node scripts/optimize-images.mjs",
		"optimize:images:check": "node scripts/optimize-images.mjs --check",
		"astro": "astro",
		"format": "npx prettier -w .",
		"format:check": "npx prettier --check .",
		"update": "pnpm dlx @astrojs/upgrade"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/markdoc": "^2.0.3",
		"@astrojs/node": "^11.0.2",
		"@astrojs/react": "^6.0.1",
		"@fontsource-variable/roboto": "^5.2.10",
		"@fullcalendar/core": "^6.1.21",
		"@fullcalendar/daygrid": "^6.1.21",
		"@fullcalendar/react": "^6.1.21",
		"@keystatic/astro": "^5.1.0",
		"@keystatic/core": "^0.5.50",
		"@lucide/astro": "^1.23.0",
		"@react-email/render": "^2.0.10",
		"@types/leaflet": "^1.9.21",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"astro": "^7.0.6",
		"leaflet": "^1.9.4",
		"react": "^19.2.7",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.7",
		"resend": "^6.17.1",
		"sharp": "^0.35.3",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@react-email/ui": "6.6.6",
		"@types/react": "^19.0.1",
		"@types/react-dom": "^19.0.1",
		"prettier": "^3.9.4",
		"prettier-plugin-astro": "^0.14.1",
		"react-email": "6.6.6",
		"vitest": "^4.1.10"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"@keystatic/astro>astro": "^7.0.0"
			}
		}
	}
}
