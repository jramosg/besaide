---
import { getLangFromUrl, getUrlFromID, useTranslations } from '@/i18n/utils';
import { sortedAndFilteredEvents } from '@/utils/events';
import HomeSectionHeader from './HomeSectionHeader.astro';
import EventCard from '@/components/events/EventCard.astro';
import HomeCalendar from '@/components/events/HomeCalendar.tsx';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const agendaSection = getUrlFromID('agenda', lang);
const today = new Date();

let events = await sortedAndFilteredEvents(agendaSection, today);
events = events.filter(event => !event.isPast);

// Group events by month key "YYYY-M"
const eventsByMonth = new Map<
	string,
	{ title: string; events: typeof events }
>();

for (const event of events) {
	const date = new Date(event.data.date);
	const key = `${date.getFullYear()}-${date.getMonth()}`;
	if (!eventsByMonth.has(key)) {
		eventsByMonth.set(key, { title: key, events: [] });
	}
	eventsByMonth.get(key)!.events.push(event);
}

// Serialize lightweight event data for the React calendar (dots only)
// Use local date parts (not toISOString which converts to UTC and can shift dates)
const formatLocalDate = (d: Date) => {
	const y = d.getFullYear();
	const m = String(d.getMonth() + 1).padStart(2, '0');
	const day = String(d.getDate()).padStart(2, '0');
	return `${y}-${m}-${day}`;
};

const calendarEvents = events.map(event => ({
	date: formatLocalDate(new Date(event.data.date)),
	endDate: event.data.endDate
		? formatLocalDate(new Date(event.data.endDate))
		: undefined,
	type: event.data.type,
	slug: event.slug
}));

// The initial month key to show (current month)
const initialMonthKey = `${today.getFullYear()}-${today.getMonth()}`;

// Get all month keys in order
const monthKeys = Array.from(eventsByMonth.keys());
---

{
	events.length > 0 ? (
		<section
			id="agenda"
			class="home-section_container"
			aria-labelledby="agenda-heading"
		>
			<HomeSectionHeader
				id="agenda-heading"
				title={t('Hurrengo irteerak')}
				buttonText={t('Agenda osoa ikusi')}
				buttonHref={getUrlFromID('agenda', lang, {
					year: new Date().getFullYear()
				})}
			>
				<div class="home-agenda-layout">
					<div class="home-agenda-calendar">
						<HomeCalendar events={calendarEvents} lang={lang} client:load />
					</div>
					<div class="home-agenda-events" id="home-agenda-events">
						{monthKeys.map(key => (
							<div
								class="home-agenda-month-group"
								data-month-key={key}
								style={key === initialMonthKey ? '' : 'display:none'}
							>
								<div class="events-grid">
									{eventsByMonth
										.get(key)!
										.events.slice(0, 6)
										.map(item => (
											<EventCard item={item} />
										))}
								</div>
							</div>
						))}

						{/* Empty state shown when current month has no events */}
						<div
							class="home-agenda-empty"
							id="home-agenda-empty"
							style={eventsByMonth.has(initialMonthKey) ? 'display:none' : ''}
						>
							<p>{t('home.calendar.no-events')}</p>
						</div>
					</div>
				</div>
			</HomeSectionHeader>
		</section>
	) : null
}

<style>
	.home-agenda-layout {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--s8);
		align-items: start;
		--cal-event-range: #a028ab33;
	}

	.home-agenda-calendar {
		position: sticky;
		top: calc(var(--header-height) + var(--s4));
	}

	.events-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: var(--s6);
	}

	.home-agenda-empty {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 200px;
		border-radius: var(--theme-shape-radius);
		background: var(--theme-primary-container-alt);
		color: var(--theme-text-secondary);
		text-align: center;
		padding: var(--s6);
	}

	.home-agenda-empty p {
		margin: 0;
		font-size: var(--font-size-lg);
	}

	/* Calendar card wrapper */
	.home-agenda-calendar :global(.home-cal-wrapper) {
		background: var(--theme-primary-50);
		border-radius: var(--theme-shape-radius);
		box-shadow: var(--shadow-card);
		padding: var(--s4) var(--s5);
	}

	/* react-day-picker theme integration */
	.home-agenda-calendar :global(.rdp-root) {
		--rdp-accent-color: var(--theme-primary-900);
		--rdp-accent-background-color: var(--theme-primary-container-alt);
		--rdp-day-height: 44px;
		--rdp-day-width: 44px;
		--rdp-day_button-height: 40px;
		--rdp-day_button-width: 40px;
		--rdp-day_button-border-radius: 50%;
		font-family: var(--theme-font-family);
	}

	.home-agenda-calendar :global(.rdp-month_caption) {
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-semibold);
		border-bottom: 2px solid var(--theme-primary-900);
		margin-bottom: var(--s2);
	}

	.home-agenda-calendar :global(.rdp-weekday) {
		color: var(--theme-text-secondary);
		font-weight: var(--font-weight-medium);
		font-size: var(--font-size-sm);
		text-transform: lowercase;
	}

	.home-agenda-calendar :global(.rdp-day_button) {
		position: relative;
		font-weight: var(--font-weight-medium);
	}

	/* Today: filled purple circle */
	.home-agenda-calendar :global(.rdp-today .rdp-day_button) {
		font-weight: var(--font-weight-bold);
		color: var(--theme-primary-800);
		border-radius: 50%;
	}

	.home-agenda-calendar :global(.rdp-nav) {
		gap: var(--s2);
	}

	.home-agenda-calendar :global(.rdp-button_next),
	.home-agenda-calendar :global(.rdp-button_previous) {
		border-radius: 50%;
		color: var(--theme-on-bg);
		transition: background-color 0.15s ease;
	}

	.home-agenda-calendar :global(.rdp-button_next:hover),
	.home-agenda-calendar :global(.rdp-button_previous:hover) {
		background-color: var(--theme-primary-hover-bg);
	}

	/* Outside-month days */
	.home-agenda-calendar :global(.rdp-outside .rdp-day_button) {
		color: var(--theme-text-secondary);
		opacity: 0.8;
	}

	/* --- Multi-day event range highlighting --- */

	/* Range start: dark purple circle + right bridge */
	.home-agenda-calendar :global(.rdp-day.cal-range-start) {
		position: relative;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-start)::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		right: 0;
		height: var(--rdp-day_button-height, 40px);
		transform: translateY(-50%);
		background-color: var(--cal-event-range);
		z-index: 0;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-start .rdp-day_button) {
		background-color: var(--theme-primary-800);
		color: var(--theme-on-primary);
		border-radius: 50%;
		position: relative;
		z-index: 1;
	}

	/* Range middle: light purple bridge, no circle */
	.home-agenda-calendar :global(.rdp-day.cal-range-middle) {
		position: relative;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-middle)::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		height: var(--rdp-day_button-height, 40px);
		transform: translateY(-50%);
		background-color: var(--cal-event-range);
		z-index: 0;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-middle .rdp-day_button) {
		background-color: transparent;
		font-weight: var(--font-weight-semibold);
		border-radius: 0;
		position: relative;
		z-index: 1;
	}

	/* Range end: dark purple circle + left bridge */
	.home-agenda-calendar :global(.rdp-day.cal-range-end) {
		position: relative;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-end)::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 0;
		right: 50%;
		height: var(--rdp-day_button-height, 40px);
		transform: translateY(-50%);
		background-color: var(--cal-event-range);
		z-index: 0;
	}
	.home-agenda-calendar :global(.rdp-day.cal-range-end .rdp-day_button) {
		background-color: var(--theme-primary-800);
		color: var(--theme-on-primary);
		border-radius: 50%;
		position: relative;
		z-index: 1;
	}

	/* Single-day event: filled primary circle */
	.home-agenda-calendar :global(.rdp-day.cal-single-event .rdp-day_button) {
		background-color: var(--theme-primary-800);
		color: var(--theme-on-primary);
		border-radius: 50%;
	}

	/* When today overlaps with an event, event style takes priority */
	.home-agenda-calendar :global(.rdp-today.cal-range-start .rdp-day_button),
	.home-agenda-calendar :global(.rdp-today.cal-range-end .rdp-day_button) {
		background-color: var(--theme-primary-800);
		color: var(--theme-on-primary);
	}
	.home-agenda-calendar :global(.rdp-today.cal-single-event .rdp-day_button) {
		background-color: var(--theme-primary);
		color: var(--theme-on-primary);
	}

	/* Dark theme overrides */

	:global([data-theme='dark']) .home-agenda-calendar :global(.rdp-root) {
		--rdp-accent-color: var(--theme-on-bg);
	}
	:global([data-theme='dark']) .home-agenda-layout {
		--cal-event-range: rgba(236, 67, 237, 0.15);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.home-cal-wrapper) {
		background: var(--theme-primary-950);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-month_caption) {
		border-bottom-color: var(--rdp-accent-color);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-today .rdp-day_button) {
		color: var(--theme-primary-300);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-day.cal-range-start .rdp-day_button),
	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-day.cal-range-end .rdp-day_button),
	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-day.cal-single-event .rdp-day_button) {
		background-color: var(--theme-primary-400);
		color: var(--theme-primary-950);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-today.cal-range-start .rdp-day_button),
	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-today.cal-range-end .rdp-day_button) {
		background-color: var(--theme-primary-400);
		color: var(--theme-primary-950);
	}

	:global([data-theme='dark'])
		.home-agenda-calendar
		:global(.rdp-today.cal-single-event .rdp-day_button) {
		background-color: var(--theme-primary-300);
		color: var(--theme-primary-950);
	}

	@media (max-width: 900px) {
		.home-agenda-layout {
			grid-template-columns: 1fr;
		}

		.home-agenda-calendar {
			position: static;
			justify-self: center;
		}

		.events-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
